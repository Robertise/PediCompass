# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# ─── Bedrock ──────────────────────────────────────────────────────────────────
# Get the exact inference profile ID by running:
#   aws bedrock list-inference-profiles --region ap-southeast-1
# Look for Claude Sonnet under inferenceProfileId (NOT the foundation model ID).
# Example format: ap.anthropic.claude-3-5-sonnet-20241022-v2:0
# Using a bare model ID (e.g. anthropic.claude-sonnet-4-5) will cause:
#   ValidationException: on-demand throughput isn't supported.
BEDROCK_MODEL_ID=ap.anthropic.claude-REPLACE-WITH-ACTUAL-ID

# For ingestion contextual retrieval (cheaper, summarization only):
#   aws bedrock list-inference-profiles --region ap-southeast-1 | grep haiku
BEDROCK_HAIKU_MODEL_ID=ap.anthropic.claude-haiku-REPLACE-WITH-ACTUAL-ID

# ─── Cognito ──────────────────────────────────────────────────────────────────
# Find in AWS Console → Cognito → User Pools → your pool → Overview
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=ap-southeast-1

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_PREFIX=pedicompass_

# ─── Qdrant (local Docker) ────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=pedicompass_kb

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
